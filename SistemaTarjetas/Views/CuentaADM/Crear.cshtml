<h2 class="titulo">Nueva Cuenta</h2>

<div class="form-wrapper">
<div class="form-panel">

@if (TempData["Error"] != null)
{
    <div class="alert error">@TempData["Error"]</div>
}

<form method="post">

    <div class="field">
        <label>Identificación</label>
        <input name="Identificacion" required />
    </div>

    <div class="field">
        <label>Monto Inicial</label>
        <input name="Monto" type="number" required />
    </div>

    <div class="actions">
        <button class="btn-main">Guardar</button>
        <a href="/CuentaADM/Cuentas" class="btn-alt">Cancelar</a>
    </div>

</form>

</div>
</div>

<style>
.titulo { text-align:center; color:#e2e8f0; }

.form-wrapper { display:flex; justify-content:center; margin-top:30px; }

.form-panel {
    width:400px;
    background:#1e293b;
    padding:30px;
    border-radius:12px;
    box-shadow:0 10px 25px rgba(0,0,0,0.4);
}

.field { margin-bottom:15px; }

label { display:block; margin-bottom:5px; color:#94a3b8; }

input {
    width:100%;
    padding:10px;
    border-radius:6px;
    border:1px solid #334155;
    background:#0f172a;
    color:white;
}

input:focus {
    outline:none;
    border-color:#2563eb;
}

.actions {
    display:flex;
    gap:10px;
    margin-top:20px;
}

.btn-main {
    flex:1;
    background:#2563eb;
    color:white;
    padding:10px;
    border:none;
    border-radius:6px;
}

.btn-alt {
    flex:1;
    background:#334155;
    color:white;
    padding:10px;
    text-align:center;
    border-radius:6px;
    text-decoration:none;
}

.alert { padding:10px; border-radius:6px; margin-bottom:15px; }
.error { background:#dc2626; }
</style>
@model List<WSAutenticador.UsuarioRegistro>

<h2 class="titulo">Administración de Usuarios</h2>

<div class="wrapper">

    <div class="header">
        <a asp-action="Crear" class="btn-main">+ Nuevo Usuario</a>
    </div>

    <div class="panel">

        <table>
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>Tipo</th>
                    <th class="center">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Usuario</td>
                        <td>
                            <span class="badge @(u.Tipo == 1 ? "admin" : "cliente")">
                                @(u.Tipo == 1 ? "Administrador" : "Cliente")
                            </span>
                        </td>

                        <td class="center actions">
                            <a asp-action="Editar" asp-route-id="@u.Identificacion"
                               class="btn-primary">Editar</a>

                            <a asp-action="Inactivar" asp-route-id="@u.Identificacion"
                               onclick="return confirm('¿Realmente desea inactivar el usuario?')"
                               class="btn-danger">Inactivar</a>

                            <a asp-action="Activar" asp-route-id="@u.Identificacion"
                               onclick="return confirm('¿Realmente desea activar el usuario?')"
                               class="btn-success">Activar</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>

<style>

    .titulo {
        text-align: center;
        color: #e2e8f0;
        margin-bottom: 20px;
    }

    .wrapper {
        max-width: 1000px;
        margin: 0 auto;
    }

    .header {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 15px;
    }

    .panel {
        background: #1e293b;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.4);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        text-align: left;
        padding: 12px;
        color: #94a3b8;
        border-bottom: 1px solid #334155;
    }

    td {
        padding: 12px;
        color: #e2e8f0;
    }

    tr:hover {
        background: #0f172a;
    }

    .center {
        text-align: center;
    }

    .actions a {
        margin: 0 3px;
    }

    /* BOTONES */
    .btn-main {
        background: #2563eb;
        color: white;
        padding: 10px 14px;
        border-radius: 8px;
        text-decoration: none;
    }

    .btn-primary {
        background: #3b82f6;
        color: white;
        padding: 6px 10px;
        border-radius: 6px;
        text-decoration: none;
    }

    .btn-danger {
        background: #dc2626;
        color: white;
        padding: 6px 10px;
        border-radius: 6px;
        text-decoration: none;
    }

    .btn-success {
        background: #16a34a;
        color: white;
        padding: 6px 10px;
        border-radius: 6px;
        text-decoration: none;
    }

    /* BADGE */
    .badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
    }

    .admin {
        background: #2563eb;
        color: white;
    }

    .cliente {
        background: #64748b;
        color: white;
    }

</style>
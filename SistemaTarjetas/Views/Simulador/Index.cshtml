@model SistemaTarjetas.Models.CompraViewModel
@{
    ViewData["Title"] = "Simulador de Compra";
}

<div class="simulador-container">
    <div class="simulador-header">
        <h1><i class="fas fa-shopping-cart"></i> Simulador de Compra</h1>
        <p>Complete los datos para realizar una compra en línea</p>
    </div>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-@ViewBag.Tipo">
            <i class="fas @ViewBag.Icono"></i>
            <span>@ViewBag.Mensaje</span>
        </div>
    }

    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Monto"></label>
            <input asp-for="Monto" class="form-control" type="number" step="0.01" id="Monto" />
            <span asp-validation-for="Monto" class="text-danger"></span>
            <small class="text-muted">Si el monto es mayor a ₡50,000, se requerirá el PIN</small>
        </div>

        <div class="form-group">
            <label asp-for="NombreCliente"></label>
            <input asp-for="NombreCliente" class="form-control" />
            <span asp-validation-for="NombreCliente" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="NumeroTarjeta"></label>
            <input asp-for="NumeroTarjeta" class="form-control" placeholder="1234 5678 9012 3456" id="NumeroTarjeta" />
            <span asp-validation-for="NumeroTarjeta" class="text-danger"></span>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label asp-for="FechaVencimiento"></label>
                <input asp-for="FechaVencimiento" class="form-control" placeholder="MM/YYYY" />
                <span asp-validation-for="FechaVencimiento" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CVV"></label>
                <input asp-for="CVV" class="form-control" type="password" maxlength="4" id="CVV" />
                <span asp-validation-for="CVV" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Comercio"></label>
            <input asp-for="Comercio" class="form-control" id="Comercio" />
            <span asp-validation-for="Comercio" class="text-danger"></span>
        </div>

        <div class="form-group pin-field" id="pinField" style="display: none;">
            <label asp-for="PIN"></label>
            <input asp-for="PIN" class="form-control" type="password" maxlength="4" />
            <span asp-validation-for="PIN" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-submit" id="btnSubmit">
            <i class="fas fa-check-circle"></i>
            <span class="btn-text">Realizar Compra</span>
            <span class="loading-spinner"></span>
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePinField() {
            var monto = parseFloat(document.getElementById('Monto').value) || 0;
            var pinField = document.getElementById('pinField');

            if (monto > 50000) {
                pinField.style.display = 'block';
            } else {
                pinField.style.display = 'none';
            }
        }

        document.getElementById('Monto').addEventListener('input', togglePinField);
        togglePinField();

        // Formatear número de tarjeta
        var tarjetaInput = document.getElementById('NumeroTarjeta');
        if (tarjetaInput) {
            tarjetaInput.addEventListener('input', function(e) {
                var value = this.value.replace(/\s/g, '');
                if (value.length > 16) value = value.slice(0, 16);
                var formatted = '';
                for (var i = 0; i < value.length; i++) {
                    if (i > 0 && i % 4 === 0) formatted += ' ';
                    formatted += value[i];
                }
                this.value = formatted;
            });
        }
    </script>
}
<style>
    .simulador-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 2rem;
    }

    .simulador-header {
        text-align: center;
        margin-bottom: 2rem;
    }

        .simulador-header h1 {
            color: #1e3a8a;
            font-size: 1.8rem;
        }

    .form-group {
        margin-bottom: 1rem;
    }

        .form-group label {
            display: block;
            margin-bottom: 0.3rem;
            font-weight: 500;
            color: #1e293b;
        }

    .form-control {
        width: 100%;
        padding: 0.6rem 0.8rem;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 1rem;
    }

        .form-control:focus {
            outline: none;
            border-color: #1e3a8a;
            box-shadow: 0 0 0 2px rgba(30, 58, 138, 0.2);
        }

    .btn-submit {
        width: 100%;
        padding: 0.8rem;
        background: #1e3a8a;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 1rem;
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            background: #2563eb;
            transform: translateY(-2px);
        }

    .alert {
        padding: 0.8rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
        border-left: 4px solid #10b981;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        border-left: 4px solid #ef4444;
    }

    .text-danger {
        color: #ef4444;
        font-size: 0.8rem;
    }

    .text-muted {
        color: #64748b;
        font-size: 0.7rem;
    }

    .pin-field {
        transition: all 0.3s ease;
    }

    .loading-spinner {
        display: none;
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 0.6s linear infinite;
    }

    .btn-submit.loading .loading-spinner {
        display: inline-block;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>
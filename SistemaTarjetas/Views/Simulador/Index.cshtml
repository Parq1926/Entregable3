@model SistemaTarjetas.Models.CompraViewModel

<h2>Simulador de Compra</h2>

@if (ViewBag.Mensaje != null)
{
    <div style="color: @(ViewBag.Tipo == "success" ? "green" : "red"); margin-bottom: 15px;">
        <strong>@ViewBag.Mensaje</strong>
    </div>
}

<form method="post">
    <div>
        <label>Número de Tarjeta:</label>
        <input asp-for="NumeroTarjeta" value="4111111111111111" />
    </div>
    <div>
        <label>Monto:</label>
        <input asp-for="Monto" value="10000" />
    </div>
    <div>
        <label>Comercio:</label>
        <input asp-for="Comercio" value="Tienda Test" />
    </div>
    <div>
        <label>CVV:</label>
        <input asp-for="CVV" value="123" />
    </div>
    <div>
        <label>Fecha Vencimiento:</label>
        <input asp-for="FechaVencimiento" value="12/2028" />
    </div>
    <div id="pinField" style="display: none;">
        <label>PIN:</label>
        <input asp-for="PIN" type="password" />
    </div>
    <button type="submit">Realizar Compra</button>
</form>

<script>
    document.getElementById('Monto').addEventListener('input', function() {
        var pinField = document.getElementById('pinField');
        if (parseFloat(this.value) > 50000) {
            pinField.style.display = 'block';
        } else {
            pinField.style.display = 'none';
        }
    });
</script>
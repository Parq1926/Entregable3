@{
    Layout = null;
    ViewData["Title"] = "Movimientos de Cuenta";
    var cuentas = ViewBag.Cuentas as List<dynamic>;
    var movimientos = ViewBag.Movimientos as List<dynamic>;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Movimientos de Cuenta - Banco ABC</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #0a2540 0%, #1c5a7a 100%);
            margin: 0;
            padding: 0;
        }
        .navbar {
            background: rgba(10, 37, 64, 0.95);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
        }
        .logo { font-size: 1.5rem; font-weight: bold; }
        .logo span { color: #ffd700; }
        .container { max-width: 800px; margin: 30px auto; padding: 0 20px; }
        .card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            margin-bottom: 20px;
        }
        .card-header {
            background: linear-gradient(135deg, #0f3b5c 0%, #1c5a7a 100%);
            padding: 15px 20px;
            color: white;
        }
        .card-body { padding: 20px; }
        select {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 1rem;
        }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #e2e8f0; }
        th { background: #f8fafc; color: #1e293b; }
        .monto { font-weight: 600; color: #10b981; }
        .btn-volver {
            display: inline-block;
            background: rgba(255,255,255,0.2);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <div class="navbar">
        <div class="logo">Banco <span>ABC</span></div>
        <div class="user-info">
            <span>Hola, @ViewBag.Usuario</span>
        </div>
    </div>

    <div class="container">
        <div class="card">
            <div class="card-header">
                <h2>Movimientos de Cuenta</h2>
            </div>
            <div class="card-body">
                <form method="get" action="/MovimientosCuenta/Index">
                    <label>Seleccione una cuenta/tarjeta:</label>
                    <select name="numeroCuenta" onchange="this.form.submit()">
                        <option value="">-- Seleccione una cuenta --</option>
                        @if (cuentas != null)
                        {
                            @foreach (var cuenta in cuentas)
                            {
                                <option value="@cuenta.NumeroTarjeta" selected="@(ViewBag.NumeroCuenta == cuenta.NumeroTarjeta)">
                                    @cuenta.NumeroTarjeta - @cuenta.Tipo - ₡ @cuenta.Saldo.ToString("N2")
                                </option>
                            }
                        }
                    </select>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.NumeroCuenta) && movimientos != null && movimientos.Count > 0)
        {
            <div class="card">
                <div class="card-header">
                    <h2>Movimientos</h2>
                </div>
                <div class="card-body">
                    <table>
                        <thead>
                            <tr><th>Fecha</th><th>Descripción</th><th>Monto</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var m in movimientos)
                            {
                                <tr>
                                    <td>@m.Fecha</td>
                                    <td>@m.Descripcion</td>
                                    <td class="monto">₡ @m.Monto.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(ViewBag.NumeroCuenta))
        {
            <div class="card">
                <div class="card-body">
                    <p>No hay movimientos para esta cuenta</p>
                </div>
            </div>
        }

        <div style="text-align: center; margin-top: 20px;">
            <a href="/CuentasTarjetas/Dashboard" class="btn-volver">Volver al menú principal</a>
        </div>
    </div>
</body>
</html>
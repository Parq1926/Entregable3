@{
    Layout = null;
    ViewData["Title"] = "Movimientos de Cuenta";
    var movimientos = ViewBag.Movimientos as List<SistemaTarjetas.Models.MovimientoCuenta>;
}

<!-- Mantén tu mismo HTML, cambia la tabla de movimientos -->
@if (!string.IsNullOrEmpty(ViewBag.NumeroCuenta))
{
    <div class="card">
        <div class="card-header">
            <h2>Movimientos de la cuenta: @ViewBag.NumeroCuenta</h2>
        </div>
        <div class="card-body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Descripción</th>
                        <th>Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @if (movimientos != null && movimientos.Any())
                    {
                        @foreach (var movimiento in movimientos)
                        {
                            <tr>
                                <td>@movimiento.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@movimiento.Descripcion</td>
                                <td class="monto">₡ @movimiento.Monto.ToString("N2")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="empty-message">No hay movimientos para esta cuenta</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
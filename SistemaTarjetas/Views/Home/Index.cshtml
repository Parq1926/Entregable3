@{
    ViewData["Title"] = "Inicio";
}

<section class="inicio-container">
    <div class="inicio-content">
        <h1>Banco ABC</h1>
        <p>Seguridad, confianza y respaldo para tu futuro financiero</p>
    </div>
</section>

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #0f172a;
    }

    .inicio-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 75vh;
        text-align: center;
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        color: white;
        padding: 20px;
    }

    .inicio-content {
        max-width: 700px;
        background-color: rgba(255, 255, 255, 0.05);
        padding: 50px 40px;
        border-radius: 20px;
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.1);
    }

        .inicio-content h1 {
            font-size: 3em;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .inicio-content p {
            font-size: 1.2em;
            color: #cbd5f5;
            margin-bottom: 0;
        }
</style>
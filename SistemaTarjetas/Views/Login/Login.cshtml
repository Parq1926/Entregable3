@model SistemaTarjetas.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<section class="login-container">
    <div class="login-content">

        <h1>Banco ABC</h1>
        <p class="subtitle">Acceso seguro a tu cuenta</p>

        <form asp-action="Login" method="post">

            <div class="form-group">
                <label asp-for="Usuario"></label>
                <input asp-for="Usuario" class="form-control" />
                <span asp-validation-for="Usuario" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Contra"></label>
                <input asp-for="Contra" class="form-control" type="password" />
                <span asp-validation-for="Contra" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-submit">Ingresar</button>
            @if (ViewBag.Error != null)
            {
                <p class="text-danger">@ViewBag.Error</p>
            }
        </form>

        <small class="seguridad">🔒 Conexión segura</small>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #0f172a;
    }

    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        padding: 20px;
    }

    .login-content {
        width: 100%;
        max-width: 400px;
        background-color: rgba(255, 255, 255, 0.05);
        padding: 40px 30px;
        border-radius: 20px;
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.1);
        color: white;
        text-align: center;
    }

        .login-content h1 {
            margin-bottom: 10px;
            font-size: 2.2em;
        }

    .subtitle {
        font-size: 1em;
        color: #cbd5f5;
        margin-bottom: 25px;
    }

    .form-group {
        margin-bottom: 15px;
        text-align: left;
    }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #cbd5f5;
            font-size: 0.9em;
        }

        .form-group input {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.2);
            background-color: rgba(255,255,255,0.08);
            color: white;
            outline: none;
        }

            .form-group input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 5px #2563eb;
            }

    .btn-submit {
        width: 100%;
        padding: 12px;
        background-color: #2563eb;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 10px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-submit:hover {
            background-color: #1d4ed8;
        }

    .seguridad {
        display: block;
        margin-top: 15px;
        font-size: 0.8em;
        color: #94a3b8;
    }

    .text-danger {
        font-size: 0.8em;
    }
</style>
@{
    Layout = null;
    ViewData["Title"] = "Movimientos de Tarjeta de Crédito";
    var movimientos = ViewBag.Movimientos as List<SistemaTarjetas.Models.MovimientoTarjeta>;
}

@if (!string.IsNullOrEmpty(ViewBag.NumeroTarjeta))
{
    <div class="card">
        <div class="card-header">
            <h2>Movimientos de la tarjeta: @ViewBag.NumeroTarjeta</h2>
        </div>
        <div class="card-body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Código de Autorización</th>
                        <th>Comercio (Cajero)</th>
                        <th>Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @if (movimientos != null && movimientos.Any())
                    {
                        @foreach (var movimiento in movimientos)
                        {
                            @if (movimiento.Exitoso)
                            {
                                <tr>
                                    <td>@movimiento.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@movimiento.CodigoAutorizacion</td>
                                    <td>@movimiento.Comercio</td>
                                    <td class="monto">₡ @movimiento.Monto.ToString("N2")</td>
                                </tr>
                            }
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="empty-message">No hay movimientos para esta tarjeta</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
@{
    Layout = null;
    ViewData["Title"] = "Dashboard - Banco ABC";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Dashboard - Banco ABC</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #0a2540 0%, #1c5a7a 100%);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .navbar {
            background: rgba(10, 37, 64, 0.95);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: bold;
        }

            .logo span {
                color: #ffd700;
            }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logout-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
        }

        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }

        .page-header {
            color: white;
            margin-bottom: 30px;
            text-align: center;
        }

        .buttons-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }

        .card-btn {
            background: white;
            border-radius: 15px;
            padding: 30px 20px;
            text-align: center;
            text-decoration: none;
            transition: transform 0.3s, box-shadow 0.3s;
            display: block;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

            .card-btn:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            }

            .card-btn i {
                font-size: 48px;
                color: #1c5a7a;
                margin-bottom: 15px;
            }

            .card-btn h3 {
                color: #1e293b;
                margin-bottom: 10px;
                font-size: 1.3rem;
            }

            .card-btn p {
                color: #64748b;
                font-size: 0.9rem;
            }

        .section-title {
            color: white;
            margin: 30px 0 20px 0;
            font-size: 1.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            margin-bottom: 30px;
        }

        .card-header {
            background: linear-gradient(135deg, #0f3b5c 0%, #1c5a7a 100%);
            padding: 15px 20px;
            color: white;
        }

        .card-body {
            padding: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #e2e8f0;
        }

        th {
            background: #f8fafc;
            color: #1e293b;
        }

        .saldo {
            font-weight: 600;
            color: #10b981;
        }

        .enlace {
            color: #1c5a7a;
            text-decoration: none;
        }

        .badge-debito {
            background: #dbeafe;
            color: #1e40af;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
        }

        .badge-credito {
            background: #fef3c7;
            color: #92400e;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
        }

        .footer {
            text-align: center;
            padding: 20px;
            color: rgba(255,255,255,0.7);
        }

        @@media (max-width: 768px) {
            .buttons-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <div class="navbar">
        <div class="logo">Banco <span>ABC</span></div>
        <div class="user-info">
            <span>Hola, @ViewBag.Usuario</span>
            <form asp-action="Logout" asp-controller="Login" method="post">
                <button type="submit" class="logout-btn">Cerrar Sesión</button>
            </form>
        </div>
    </div>

    <div class="container">
        <div class="page-header">
            <h1>Panel de Cliente</h1>
            <p>Selecciona una opción para gestionar tus finanzas</p>
        </div>

        <!-- BOTONES DE NAVEGACIÓN USR2, USR3, USR4 -->
        <div class="buttons-grid">
            <!-- USR2: Lista de cuentas y tarjetas -->
            <a href="/CuentasTarjetas/Dashboard" class="card-btn">
                <i class="fas fa-list"></i>
                <h3>Lista de cuentas y tarjetas</h3>
                <p>Ver el resumen de tus cuentas y tarjetas</p>
            </a>

            <!-- USR3: Movimientos de cuentas -->
            <a href="/MovimientosCuenta/Index" class="card-btn">
                <i class="fas fa-chart-line"></i>
                <h3>Movimientos de cuentas</h3>
                <p>Consultar los movimientos de tus cuentas</p>
            </a>

            <!-- USR4: Movimientos de tarjetas de crédito -->
            <a href="/MovimientosTarjetaCredito/Index" class="card-btn">
                <i class="fas fa-credit-card"></i>
                <h3>Movimientos de tarjetas de crédito</h3>
                <p>Consultar los movimientos de tus tarjetas de crédito</p>
            </a>
        </div>

        <!-- SECCIÓN DE CUENTAS (USR2) -->
        <div class="section-title">
            <i class="fas fa-chart-line"></i> Mis Cuentas
        </div>
        <div class="card">
            <div class="card-header">
                <h3>Listado de Cuentas</h3>
            </div>
            <div class="card-body">
                <table>
                    <thead>
                        <tr>
                            <th>Número de Cuenta</th>
                            <th>Saldo</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <a href="/MovimientosCuenta/Index?numeroCuenta=100-123456-7" class="enlace">
                                    100-123456-7
                                </a>
                            </td>
                            <td class="saldo">₡ 150,000.00</td>
                        </tr>
                        <tr>
                            <td>
                                <a href="/MovimientosCuenta/Index?numeroCuenta=100-765432-1" class="enlace">
                                    100-765432-1
                                </a>
                            </td>
                            <td class="saldo">₡ 25,500.00</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- SECCIÓN DE TARJETAS (USR2) -->
        <div class="section-title">
            <i class="fas fa-credit-card"></i> Mis Tarjetas
        </div>
        <div class="card">
            <div class="card-header">
                <h3>Listado de Tarjetas</h3>
            </div>
            <div class="card-body">
                <table>
                    <thead>
                        <tr>
                            <th>Número de Tarjeta</th>
                            <th>Tipo</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <a href="/MovimientosCuenta/Index?numeroCuenta=100-123456-7" class="enlace">
                                    9111-11**-****-1234
                                </a>
                            </td>
                            <td><span class="badge-debito">Débito</span></td>
                        </tr>
                        <tr>
                            <td>
                                <a href="/MovimientosTarjetaCredito/Index?numeroTarjeta=9111-12**-****-5678" class="enlace">
                                    9111-12**-****-5678
                                </a>
                            </td>
                            <td><span class="badge-credito">Crédito</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="footer">
        <p>Banco ABC - Todos los derechos reservados</p>
    </div>

</body>
</html>
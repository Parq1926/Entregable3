<h2 class="titulo">Nuevo Cliente</h2>

<div class="form-wrapper">
<div class="form-panel">

@if (TempData["Success"] != null)
{
    <div class="alert success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert error">@TempData["Error"]</div>
}

<form asp-action="Crear" method="post">

    <div class="field">
        <label>ID</label>
        <input name="Identificacion" required />
    </div>

    <div class="field">
        <label>Nombre</label>
        <input name="Nombre" required />
    </div>

    <div class="field">
        <label>Apellido 1</label>
        <input name="Apellido1" required />
    </div>

    <div class="field">
        <label>Apellido 2</label>
        <input name="Apellido2" />
    </div>

    <div class="actions">
        <button class="btn-main">Guardar</button>
        <a href="/ClientesADM/Clientes" class="btn-alt">Cancelar</a>
    </div>

</form>

</div>
</div>

<style>
.titulo {
    text-align:center;
    color:#e2e8f0;
}

.form-wrapper {
    display:flex;
    justify-content:center;
    margin-top:30px;
}

.form-panel {
    width:420px;
    background:#1e293b;
    padding:30px;
    border-radius:12px;
}

.field {
    margin-bottom:15px;
}

label {
    display:block;
    margin-bottom:5px;
    color:#94a3b8;
}

input {
    width:100%;
    padding:10px;
    border-radius:6px;
    border:1px solid #334155;
    background:#0f172a;
    color:white;
}

.actions {
    display:flex;
    gap:10px;
    margin-top:20px;
}

.btn-main {
    flex:1;
    background:#2563eb;
    color:white;
    padding:10px;
    border:none;
    border-radius:6px;
}

.btn-alt {
    flex:1;
    background:#334155;
    color:white;
    padding:10px;
    text-align:center;
    border-radius:6px;
    text-decoration:none;
}

/* ALERTAS */
.alert {
    padding:10px;
    border-radius:6px;
    margin-bottom:15px;
}

.success { background:#16a34a; }
.error { background:#dc2626; }
</style>
<h2 class="titulo">Editar Cliente</h2>

<div class="form-wrapper">
<div class="form-panel">

@if (TempData["Success"] != null)
{
    <div class="alert success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert error">@TempData["Error"]</div>
}

<form asp-action="Editar" method="post">

    <input type="hidden" name="IdentificacionOriginal" value="@ViewBag.Cliente.Identificacion" />

    <div class="field">
        <label>ID</label>
        <input name="Identificacion" value="@ViewBag.Cliente.Identificacion" required />
    </div>

    <div class="field">
        <label>Nombre</label>
        <input name="Nombre" value="@ViewBag.Cliente.Nombre" required />
    </div>

    <div class="field">
        <label>Apellido 1</label>
        <input name="Apellido1" value="@ViewBag.Cliente.Apellido1" required />
    </div>

    <div class="field">
        <label>Apellido 2</label>
        <input name="Apellido2" value="@ViewBag.Cliente.Apellido2" />
    </div>

    <div class="actions">
        <button type="submit" class="btn-main">Guardar</button>
        <a href="/ClientesADM/Clientes" class="btn-alt">Cancelar</a>
    </div>

</form>

</div>
</div>

<style>
/* TÍTULO */
.titulo {
    text-align:center;
    color:#e2e8f0;
    margin-bottom:10px;
}

/* CONTENEDOR */
.form-wrapper {
    display:flex;
    justify-content:center;
    margin-top:30px;
}

/* PANEL */
.form-panel {
    width:420px;
    background:#1e293b;
    padding:30px;
    border-radius:12px;
    box-shadow:0 10px 25px rgba(0,0,0,0.4);
}

/* CAMPOS */
.field {
    margin-bottom:15px;
}

label {
    display:block;
    margin-bottom:5px;
    color:#94a3b8;
    font-size:14px;
}

input {
    width:100%;
    padding:10px;
    border-radius:6px;
    border:1px solid #334155;
    background:#0f172a;
    color:white;
    transition:0.2s;
}

/* EFECTO FOCUS */
input:focus {
    outline:none;
    border-color:#2563eb;
    box-shadow:0 0 0 1px #2563eb;
}

/* BOTONES */
.actions {
    display:flex;
    gap:10px;
    margin-top:20px;
}

.btn-main {
    flex:1;
    background:#2563eb;
    color:white;
    padding:10px;
    border:none;
    border-radius:6px;
    font-weight:500;
    cursor:pointer;
}

.btn-main:hover {
    background:#1d4ed8;
}

.btn-alt {
    flex:1;
    background:#334155;
    color:white;
    padding:10px;
    text-align:center;
    border-radius:6px;
    text-decoration:none;
}

.btn-alt:hover {
    background:#475569;
}

/* ALERTAS */
.alert {
    padding:10px;
    border-radius:6px;
    margin-bottom:15px;
    text-align:center;
}

.success { background:#16a34a; }
.error { background:#dc2626; }
</style>